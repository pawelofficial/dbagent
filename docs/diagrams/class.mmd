classDiagram
    class Waiter {
        +String name
        +greet(client: Client)
        +receive_order(order: Order)
        -check_availability(item: Item, inventory: Inventory)
        +give_check(check: Check)
    }

    class Client {
        +String name
        +greet(waiter: Waiter)
        +order_item(item: Item)
        +ask_for_check(waiter: Waiter)
    }

    class Order {
        +List items
        +add_item(item: Item)
    }

    class Check {
        +List items
        +calculate_amount(menu: Menu) float
    }

    class Item {
        +String name
        +bool availability
        +float price
    }

    class Inventory {
        +List items
        +check_availability(item: Item) bool
    }

    class Menu {
        +Dict prices
        +get_price(item: Item) float
    }

    class Database {
        +String connection_string
        +connect()
        +query(sql: str) List
    }
    
    class MenuRepository {
        -db: Database
        +load_menu() Menu
    }
    
    class InventoryRepository {
        -db: Database
        +load_inventory() Inventory
    }