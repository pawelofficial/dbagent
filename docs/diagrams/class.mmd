classDiagram
    class Waiter {
        +String name
        -Order _current_order
        +greets(client: Client)
        +receive_order(order: Order)
        -check_availability(item: Item, inventory: Inventory) bool
        +check_and_add(item: Item, order: Order, inventory: Inventory) bool
        +confirm(client: Client)
        +give_check(client: Client, check: Check)
        +prepare_check(order: Order, menu: Menu, db: Database) Check
    }

    class Client {
        +String name
        +greets(waiter: Waiter)
        +orders_item(item: Item) Item
        +place_order(order: Order, waiter: Waiter)
        +ask_for_check(waiter: Waiter)
    }

    class Order {
        +List~Item~ items
        +add_item(item: Item)
    }

    class Check {
        +List~Item~ items
        +float total
        +calculate_amount(menu: Menu) float
        +save(db: Database)
    }

    class Item {
        +String name
        +bool availability
        +float price
    }

    class Inventory {
        +List~Item~ items
        +check_availability(item: Item) bool
    }

    class Menu {
        +Dict prices
        +get_price(item: Item) float
    }

    class Database {
        +String connection_string
        -Connection _conn
        +connect()
        +query(sql: str, params: tuple) List
        +execute(sql: str, params: tuple)
        +seed()
    }

    class MenuRepository {
        -db: Database
        +load_menu() Menu
    }

    class InventoryRepository {
        -db: Database
        +load_inventory() Inventory
    }

    %% Aggregation - holds a collection as a field
    Order o-- Item : contains
    Inventory o-- Item : stocks
    Check o-- Item : lists

    %% Association - uses in method params, doesn't hold
    Waiter --> Client : serves
    Client --> Order : places
    Waiter --> Order : receives
    Waiter --> Inventory : checks stock
    Waiter --> Check : requests
    Menu --> Item : looks up price

    %% Composition - owns as a field, tightly coupled
    MenuRepository *-- Database : has db
    InventoryRepository *-- Database : has db

    %% Dependencies - only used as return types in methods
    MenuRepository ..> Menu : produces
    InventoryRepository ..> Inventory : produces
    Check ..> Menu : uses for pricing
    Check ..> Database : saves to